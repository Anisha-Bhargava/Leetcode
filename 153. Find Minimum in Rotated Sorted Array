BRUTE FORCE

class Solution {
public:
    int findMin(vector<int>& nums) {
        int mini=INT_MAX;
        for(int i=0;i<nums.size();i++){
            mini = min(mini,nums[i]);
        }
        return mini;
    }
};


OPTIMAL APPROCH (TC - O(logn))

class Solution {
public:
    int findMin(vector<int>& nums) {
        int low=0;
        int high=nums.size()-1;
        while(low<high){
            int mid = low + (high-low)/2;
            if(nums[mid]>nums[high]) low=mid+1;
            else high = mid;
        }
        return nums[low];
    }
};
