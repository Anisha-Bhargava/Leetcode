class Solution {
public:
    long long totalTime(vector<int>& time, long long t){
        int n = time.size();
        long long sum = 0;

        for(int i = 0; i < n; i++){
            sum += t / time[i];
        }

        return sum;
    }

    long long minimumTime(vector<int>& time, int totalTrips) {
        long long mini = *min_element(time.begin(), time.end());

        long long low = 1;
        long long high = mini * totalTrips;
        long long ans = -1;

        while(low <= high){
            long long mid = low + (high - low) / 2;

            if(totalTime(time, mid) >= totalTrips){
                ans = mid;
                high = mid - 1;
            }
            else low = mid + 1;
        }
        return ans;
    }
};
