            else{
                noOfb += (cnt/k);
                cnt=0;
            }
        }
        noOfb += (cnt/k);
        if(noOfb >= m) return true;
        else return false;
    }


    int minDays(vector<int>& bloomDay, int m, int k) {
        int n = bloomDay.size();
        if(m*k> n) return -1;
        int mini = *min_element(bloomDay.begin(), bloomDay.end());
        int maxi = *max_element(bloomDay.begin(), bloomDay.end());

